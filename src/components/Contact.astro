---
import { site, socials } from "../data/site";
---
<section class="contact" id="contact">
  <div class="eyebrow eyebrow--accent">Let's talk</div>
  <h2 class="contact-title">Have something to build?</h2>
  <p class="contact-text">
    Whether it's a product, a consult, or a collaboration — I'd love to hear about it.
  </p>
  <div class="contact-btns">
    <a class="btn btn-primary" href={`mailto:${site.email}`}>{site.email}</a>
    {/* TODO: replace with a real scheduling link (Cal.com / Calendly) */}
    <a class="btn btn-secondary" href={`mailto:${site.email}?subject=Booking%20a%20call`}>Book a call</a>
  </div>
  <div class="socials">
    {socials.map((s) => (
      <a
        class="social-link"
        href={s.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.name}
        title={s.name}
      >{s.label}</a>
    ))}
  </div>
</section>
