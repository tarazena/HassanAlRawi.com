---
import "../styles/about.css";
// About section. Drop a portrait in /public and replace the placeholder
// span below with <img src="/your-portrait.jpg" alt="Hassan Al Rawi" />.
---
<section class="about" id="about">
  <div class="about-photo">
    <span class="thumb-placeholder">Portrait</span>
  </div>
  <div class="about-copy">
    <div class="section-label">About</div>
    <h2 class="about-title">I build at the seam of engineering and design.</h2>
    <p class="about-text">
      I'm a software engineer who ships products end to end — and the founder of
      IFF Productions, where I turn ideas into real, running things. I care about
      systems that are clean under the hood and obvious on the surface.
    </p>
    <p class="about-text">
      Outside the editor I'm a <span class="accent">photographer</span> and
      <span class="accent">musician</span> — the same instinct for composition,
      rhythm, and detail, in a different medium.
    </p>
  </div>
</section>
