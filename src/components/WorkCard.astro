---
import type { Project } from "../data/site";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const hasLink = project.href !== "#";
const isExternal = project.href.startsWith("http");
---
<article class="work-card">
  <div class="work-thumb">
    {project.image
      ? <img src={project.image} alt={project.title} />
      : <span class="thumb-placeholder">Project image</span>}
  </div>
  <div class="work-row">
    <div class="work-title">{project.title}</div>
    {hasLink
      ? <a
          class="work-view"
          href={project.href}
          {...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >View →</a>
      : <span class="work-view work-view--soon">In progress</span>}
  </div>
  <p class="work-blurb">{project.blurb}</p>
  <div class="tags">
    {project.tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</article>
