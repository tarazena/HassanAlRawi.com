---
// Standalone, print-optimized résumé page. Rendered to /public/resume.pdf by
// scripts/generate-resume-pdf.mjs (Puppeteer). Intentionally does NOT use
// BaseLayout — no nav/footer/theme — so the PDF is a clean document.
import { Content, frontmatter } from "../data/resume.md";

const fm = frontmatter;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fm.name} — Résumé</title>
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <article class="resume">
      <header class="resume-head">
        <h1>{fm.name}</h1>
        <p class="resume-title">{fm.title}</p>
        <p class="resume-contact">
          <span>{fm.location}</span>
          <span aria-hidden="true">·</span>
          <span>{fm.phone}</span>
          <span aria-hidden="true">·</span>
          <a href={`mailto:${fm.email}`}>{fm.email}</a>
          <span aria-hidden="true">·</span>
          <a href={fm.linkedinUrl}>{fm.linkedin}</a>
        </p>
      </header>
      <div class="resume-body">
        <Content />
      </div>
    </article>

    <style is:global>
      :root {
        --ink: #2c2a25;
        --muted: #57534c;
        --accent: #41509e;
        --rule: #d8d4cd;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: #ffffff; }
      body {
        font-family: "IBM Plex Sans", system-ui, sans-serif;
        color: var(--ink);
        font-size: 10.6px;
        line-height: 1.42;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .resume {
        max-width: 760px;
        margin: 0 auto;
        padding: 40px 44px;
      }

      /* Header */
      .resume-head { text-align: center; margin-bottom: 14px; }
      .resume-head h1 {
        font-family: "Sora", sans-serif;
        font-size: 27px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--accent);
        margin: 0 0 3px;
      }
      .resume-title {
        font-family: "Sora", sans-serif;
        font-weight: 600;
        font-size: 12.5px;
        color: var(--ink);
        margin: 0 0 6px;
        letter-spacing: 0.01em;
      }
      .resume-contact {
        font-size: 10.2px;
        color: var(--muted);
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        justify-content: center;
      }
      .resume-contact a { color: var(--accent); text-decoration: none; }
      .resume-contact span[aria-hidden] { color: var(--rule); }

      /* Sections */
      .resume-body h2 {
        font-family: "Sora", sans-serif;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--accent);
        border-bottom: 1.5px solid var(--rule);
        padding-bottom: 3px;
        margin: 16px 0 9px;
      }
      .resume-body h3 {
        font-family: "Sora", sans-serif;
        font-size: 11.6px;
        font-weight: 600;
        color: var(--ink);
        margin: 11px 0 1px;
      }
      /* The "**Title** · dates" line that follows each company heading. */
      .resume-body h3 + p {
        margin: 0 0 4px;
        font-size: 10.4px;
        color: var(--muted);
      }
      .resume-body h3 + p strong { color: var(--ink); font-weight: 600; }

      .resume-body p { margin: 0 0 7px; }
      .resume-body ul {
        margin: 0 0 8px;
        padding-left: 16px;
      }
      .resume-body li { margin: 0 0 2.5px; }
      .resume-body strong { font-weight: 600; }
      .resume-body a { color: var(--accent); text-decoration: none; }

      /* Avoid awkward breaks inside a role when printing. */
      .resume-body h2, .resume-body h3 { break-after: avoid; }
      .resume-body ul, .resume-body h3 + p { break-inside: avoid; }

      @page {
        size: Letter;
        margin: 0;
      }
      @media print {
        .resume { padding: 36px 44px; max-width: none; }
      }

      /* Screen-only: give the page a soft backdrop so it reads as a document. */
      @media screen {
        body { background: #ece9e4; padding: 24px 0; }
        .resume {
          background: #fff;
          box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
          border-radius: 4px;
        }
      }
    </style>
  </body>
</html>
