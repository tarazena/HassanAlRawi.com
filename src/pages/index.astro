// Hassan Al Rawi — personal site
// Neumorphic design ported from the Claude Design project
// "Improving neomorphic personal site". Body copy is Hassan's own; real
// contact + social links are wired in from the previous site's constants.

const email = "hassan@iffproductions.com";

// Social links carried over from the old site (src -> backup/src/core/constants.ts).
// `label` is the 2-letter mono badge shown in the design.
const socials = [
  { label: "GH", name: "GitHub", url: "https://github.com/tarazena" },
  { label: "IN", name: "LinkedIn", url: "https://www.linkedin.com/in/hassan-al-rawi-19112a87/" },
  { label: "TW", name: "Twitter", url: "https://twitter.com/hassanalrawi" },
  { label: "SC", name: "SoundCloud", url: "https://soundcloud.com/hassan-ali-al-rawi" },
  { label: "VI", name: "Vimeo", url: "https://vimeo.com/user18375922" },
  { label: "FL", name: "Flickr", url: "https://www.flickr.com/photos/tarazena" },
