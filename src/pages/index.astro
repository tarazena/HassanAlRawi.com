---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Hassan Al Rawi — Software Engineer &amp; Founder</title>
  <meta name="description" content="Hassan Al Rawi — software engineer, designer, photographer & musician. Founder of IFF Productions. I build products end to end." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#e9e6e1" />

  <meta property="og:title" content="Hassan Al Rawi — Software Engineer & Founder" />
  <meta property="og:description" content="Engineer, designer, photographer & musician. Founder of IFF Productions." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.hassanalrawi.com" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet" />

  {/* Apply saved theme before first paint to avoid a flash. */}
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem("hr-theme") || "light";
        document.documentElement.dataset.theme = t;
      } catch (e) {}
    })();
  </script>
</head>

<body>
  <main class="root">
    <div class="wrap">

      <!-- ===================== NAV ===================== -->
      <nav class="nav">
        <a class="nav-brand" href="#top" aria-label="Hassan Al Rawi — home">
          <span class="nav-logo">
            <svg width="20" height="21" viewBox="0 0 64 66" fill="none" stroke="var(--accent)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" style="transform:scaleX(-1)">
              <path d="M14 60 L14 25 C 14 11, 34 11, 34 25 L34 60"></path>
              <path d="M50 60 L50 25"></path>
              <path d="M14 42 L50 42"></path>
            </svg>
          </span>
          <span class="nav-text">
            <span class="nav-name">Hassan Al Rawi</span>
            <span class="nav-sub">IFF Productions</span>
          </span>
        </a>
        <div class="nav-links">
          <a class="nav-link" data-nav href="#work">Work</a>
          <a class="nav-link" data-nav href="#about">About</a>
          <a class="nav-link" data-nav href="#stack">Stack</a>
          <a class="nav-cta" href="#contact">Get in touch</a>
          <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme">
            <span data-theme-icon>☾</span>
          </button>
        </div>
      </nav>

      <!-- ===================== HERO ===================== -->
      <section class="hero" id="top">
        <div class="hero-copy">
          <div class="badge">
            <span class="badge-dot"></span>
            <span>Open to work &amp; consulting</span>
          </div>
          <div class="eyebrow">Software Engineer &amp; Founder</div>
          <h1 class="h1">Hassan<br />Al Rawi</h1>
          <p class="lead">Engineer, designer, photographer &amp; musician. I build products end to end — and founded <span class="accent">IFF Productions</span> to ship a few of my own.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#contact">Get in touch</a>
            <!-- TODO: link to a real résumé PDF (drop it in /public and point href here) -->
            <a class="btn btn-secondary" href="#contact">Résumé ↓</a>
          </div>
        </div>
        <div class="hero-art" aria-hidden="true">
          <div class="art-orbit">
            <div class="art-orbit-dot art-orbit-dot--top"></div>
            <div class="art-orbit-dot art-orbit-dot--bottom"></div>
          </div>
          <div class="art-blob"><div class="art-blob-core"></div></div>
          <div class="art-float art-float--1"></div>
          <div class="art-float art-float--2"></div>
        </div>
      </section>

      <!-- ===================== STATS ===================== -->
      <section class="stats">
        <div class="stat">
          <div class="stat-num">10+</div>
          <div class="stat-label">Years building</div>
        </div>
        <div class="stat">
          <div class="stat-num stat-num--sm">IFF Productions</div>
          <div class="stat-label">Founder</div>
        </div>
        <div class="stat">
          <div class="stat-num">∞</div>
          <div class="stat-label">Disciplines — code, design, photo, music</div>
        </div>
      </section>

      <!-- ===================== WHAT I DO ===================== -->
      <div class="section-label">What I do</div>
      <section class="do">
        <article class="do-card">
          <div class="do-num">01</div>
          <h3 class="do-title">Development</h3>
          <p class="do-text">Full-stack web &amp; product engineering — from architecture to shipped, performant interfaces.</p>
        </article>
        <article class="do-card">
          <div class="do-num">02</div>
          <h3 class="do-title">Design</h3>
          <p class="do-text">Product, brand &amp; graphic design with an engineer's eye for systems and detail.</p>
        </article>
        <article class="do-card">
          <div class="do-num">03</div>
          <h3 class="do-title">Consulting</h3>
          <p class="do-text">Technical strategy &amp; problem solving for teams that need to move fast and ship right.</p>
        </article>
      </section>

      <!-- ===================== SELECTED WORK ===================== -->
      <div class="work-head" id="work">
        <h2 class="section-title">Selected work</h2>
        <span class="section-meta">IFF Productions &amp; clients</span>
      </div>
      <section class="work">
        {projects.map((p) => (
          <article class="work-card">
            <div class="work-thumb">
              {p.image
                ? <img src={p.image} alt={p.title} />
                : <span class="thumb-placeholder">Project image</span>}
            </div>
            <div class="work-row">
              <div class="work-title">{p.title}</div>
              <a class="work-view" href={p.href}>View →</a>
            </div>
            <p class="work-blurb">{p.blurb}</p>
            <div class="tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </article>
        ))}
      </section>

      <!-- ===================== ABOUT ===================== -->
      <section class="about" id="about">
        <div class="about-photo">
          <!-- TODO: drop a portrait in /public and replace this placeholder with <img> -->
          <span class="thumb-placeholder">Portrait</span>
        </div>
        <div class="about-copy">
          <div class="section-label">About</div>
          <h2 class="about-title">I build at the seam of engineering and design.</h2>
          <p class="about-text">I'm a software engineer who ships products end to end — and the founder of IFF Productions, where I turn ideas into real, running things. I care about systems that are clean under the hood and obvious on the surface.</p>
          <p class="about-text">Outside the editor I'm a <span class="accent">photographer</span> and <span class="accent">musician</span> — the same instinct for composition, rhythm, and detail, in a different medium.</p>
        </div>
      </section>

      <!-- ===================== STACK ===================== -->
      <section class="stack-section" id="stack">
        <div class="section-label">What I use</div>
        <div class="chips">
          {stack.map((s) => <span class="chip">{s}</span>)}
        </div>
      </section>

      <!-- ===================== CONTACT ===================== -->
      <section class="contact" id="contact">
        <div class="eyebrow eyebrow--accent">Let's talk</div>
        <h2 class="contact-title">Have something to build?</h2>
        <p class="contact-text">Whether it's a product, a consult, or a collaboration — I'd love to hear about it.</p>
        <div class="contact-btns">
          <a class="btn btn-primary" href={`mailto:${email}`}>{email}</a>
          <!-- TODO: replace with a real scheduling link (Cal.com / Calendly) -->
          <a class="btn btn-secondary" href={`mailto:${email}?subject=Booking%20a%20call`}>Book a call</a>
        </div>
        <div class="socials">
          {socials.map((s) => (
            <a class="social-link" href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name} title={s.name}>{s.label}</a>
          ))}
        </div>
      </section>

      <!-- ===================== FOOTER ===================== -->
      <footer class="footer">
        <div>© 2026 Hassan Al Rawi · IFF Productions</div>
        <a href="#top">Back to top ↑</a>
      </footer>

    </div>
  </main>

  <script is:inline>
    (function () {
      var btn = document.getElementById("themeToggle");
      var icon = btn && btn.querySelector("[data-theme-icon]");
      function sync() {
        var dark = document.documentElement.dataset.theme === "dark";
        if (icon) icon.textContent = dark ? "☀" : "☾";
      }
      sync();
      if (btn) {
        btn.addEventListener("click", function () {
          var next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem("hr-theme", next); } catch (e) {}
          sync();
        });
      }
    })();
  </script>
</body>
</html>

<style is:global>
  /* ---------------- Palettes ---------------- */
  :root,
  :root[data-theme="light"] {
    --surface: #e9e6e1;
    --shd: #cdc9c2;
    --shl: #fbf9f5;
    --well: #e4e0da;
    --strong: #2c2a25;
    --text: #3a3631;
    --mute: #6a655d;
    --dim: #857f76;
    --faint: #a39d93;
    --accent: #41509e;
    --on-accent: #fbf9f5;
  }
  :root[data-theme="dark"] {
    --surface: #262320;
    --shd: #1a1714;
    --shl: #322e29;
    --well: #211d17;
    --strong: #f0ebe3;
    --text: #cfc8bd;
    --mute: #b3ada2;
    --dim: #938d81;
    --faint: #807a70;
    --accent: #9aa9e6;
    --on-accent: #1f1b16;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; }
  a { color: inherit; }

  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes blobBreath {
    0%, 100% { transform: scale(1); border-radius: 62% 38% 46% 54% / 60% 51% 49% 40%; }
    50% { transform: scale(1.07); border-radius: 42% 58% 62% 38% / 40% 49% 51% 60%; }
  }
  @keyframes floatY { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  @keyframes floatY2 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(10px); } }

  .root {
    display: block;
    min-height: 100vh;
    background: var(--surface);
    font-family: "IBM Plex Sans", sans-serif;
    color: var(--text);
    padding: 28px 24px 60px;
    transition: background 0.35s ease, color 0.35s ease;
  }
  .wrap { max-width: 940px; margin: 0 auto; }
  .accent { color: var(--accent); font-weight: 600; }

  /* ---------------- Nav ---------------- */
  .nav {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 13px 16px 13px 18px; border-radius: 22px; background: var(--surface);
    box-shadow: 7px 7px 16px var(--shd), -7px -7px 16px var(--shl); margin-bottom: 52px;
  }
  .nav-brand { display: flex; align-items: center; gap: 11px; text-decoration: none; }
  .nav-logo {
    width: 36px; height: 36px; border-radius: 12px; background: var(--surface);
    box-shadow: 4px 4px 9px var(--shd), -4px -4px 9px var(--shl);
    display: flex; align-items: center; justify-content: center;
  }
  .nav-name { font-family: "Sora", sans-serif; font-weight: 700; font-size: 14px; letter-spacing: -0.01em; color: var(--strong); line-height: 1; display: block; }
  .nav-sub { font-family: "IBM Plex Mono", monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--faint); margin-top: 3px; display: block; }
  .nav-links { display: flex; align-items: center; gap: 6px; }
  .nav-link {
    text-decoration: none; font-size: 13.5px; font-weight: 600; color: var(--mute);
    padding: 9px 14px; border-radius: 11px; transition: color 0.2s ease, box-shadow 0.2s ease;
  }
  .nav-link:hover { color: var(--strong); box-shadow: inset 2px 2px 5px var(--shd), inset -2px -2px 5px var(--shl); }
  .nav-cta {
    text-decoration: none; font-size: 13.5px; font-weight: 700; color: var(--on-accent);
    background: var(--accent); padding: 10px 18px; border-radius: 12px; margin-left: 6px; white-space: nowrap;
    box-shadow: 4px 4px 10px var(--shd), -4px -4px 10px var(--shl); transition: transform 0.2s ease;
  }
  .nav-cta:hover { transform: translateY(-2px); }
  .theme-toggle {
    margin-left: 4px; width: 40px; height: 40px; flex: none; border: none; cursor: pointer;
    border-radius: 12px; background: var(--surface); color: var(--mute);
    box-shadow: 4px 4px 9px var(--shd), -4px -4px 9px var(--shl);
    display: flex; align-items: center; justify-content: center; font-size: 16px; line-height: 1; padding: 0;
    transition: color 0.2s ease, box-shadow 0.2s ease;
  }
  .theme-toggle:hover { color: var(--accent); box-shadow: inset 3px 3px 7px var(--shd), inset -3px -3px 7px var(--shl); }

  /* ---------------- Hero ---------------- */
  .hero { display: flex; align-items: center; gap: 28px; margin-bottom: 30px; }
  .hero-copy { flex: 1; min-width: 0; }
  .badge {
    display: inline-flex; align-items: center; gap: 8px; padding: 7px 13px; border-radius: 30px;
    background: var(--surface); box-shadow: inset 3px 3px 6px var(--shd), inset -3px -3px 6px var(--shl); margin-bottom: 22px;
  }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #7aa06a; display: inline-block; box-shadow: 0 0 0 3px rgba(122, 160, 106, 0.18); }
  .badge span:last-child { font-size: 12px; font-weight: 600; color: var(--mute); }
  .eyebrow { font-family: "IBM Plex Mono", monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; }
  .h1 { font-family: "Sora", sans-serif; font-size: 62px; line-height: 0.98; margin: 0 0 20px; font-weight: 700; letter-spacing: -0.025em; color: var(--strong); }
  .lead { margin: 0 0 26px; max-width: 440px; font-size: 16.5px; line-height: 1.6; color: var(--mute); }
  .hero-actions { display: flex; gap: 13px; }

  .btn { text-decoration: none; white-space: nowrap; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .btn-primary {
    padding: 15px 26px; border-radius: 16px; font-size: 14.5px; font-weight: 700; color: var(--on-accent);
    background: var(--accent); box-shadow: 6px 6px 14px var(--shd), -6px -6px 14px var(--shl);
  }
  .btn-secondary {
    padding: 15px 26px; border-radius: 16px; font-size: 14.5px; font-weight: 700; color: var(--accent);
    background: var(--surface); box-shadow: 6px 6px 14px var(--shd), -6px -6px 14px var(--shl);
  }
  .btn-primary:hover, .btn-secondary:hover { transform: translateY(-3px); box-shadow: 9px 10px 20px var(--shd), -9px -9px 20px var(--shl); }

  .hero-art { flex: none; width: 190px; height: 230px; position: relative; }
  .art-orbit { position: absolute; top: 50%; left: 50%; width: 178px; height: 178px; margin: -89px 0 0 -89px; animation: spin 18s linear infinite; }
  .art-orbit-dot { position: absolute; border-radius: 50%; }
  .art-orbit-dot--top { top: -7px; left: 50%; width: 16px; height: 16px; margin-left: -8px; background: var(--surface); box-shadow: 3px 3px 7px var(--shd), -3px -3px 7px var(--shl); }
  .art-orbit-dot--bottom { bottom: -5px; left: 50%; width: 10px; height: 10px; margin-left: -5px; background: var(--accent); opacity: 0.8; }
  .art-blob {
    position: absolute; top: 50%; left: 50%; width: 120px; height: 120px; margin: -60px 0 0 -60px;
    background: var(--surface); box-shadow: 11px 11px 24px var(--shd), -11px -11px 24px var(--shl);
    animation: blobBreath 7s ease-in-out infinite; display: flex; align-items: center; justify-content: center;
  }
  .art-blob-core { width: 44px; height: 44px; border-radius: 50%; background: var(--surface); box-shadow: inset 4px 4px 8px var(--shd), inset -4px -4px 8px var(--shl); }
  .art-float { position: absolute; border-radius: 50%; background: var(--surface); box-shadow: 4px 4px 8px var(--shd), -4px -4px 8px var(--shl); }
  .art-float--1 { top: 14px; right: 6px; width: 18px; height: 18px; animation: floatY 5s ease-in-out infinite; }
  .art-float--2 { bottom: 20px; left: 0; width: 13px; height: 13px; animation: floatY2 6s ease-in-out infinite; }

  /* ---------------- Stats ---------------- */
  .stats { display: flex; gap: 14px; margin-bottom: 64px; }
  .stat { flex: 1; padding: 18px 22px; border-radius: 18px; background: var(--surface); box-shadow: 5px 5px 12px var(--shd), -5px -5px 12px var(--shl); }
  .stat-num { font-family: "Sora", sans-serif; font-size: 26px; font-weight: 700; color: var(--strong); }
  .stat-num--sm { font-size: 22px; letter-spacing: -0.01em; }
  .stat-label { font-size: 12.5px; color: var(--dim); margin-top: 2px; }

  /* ---------------- Section labels ---------------- */
  .section-label { font-family: "IBM Plex Mono", monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); margin-bottom: 18px; }
  .section-title { font-family: "Sora", sans-serif; font-size: 30px; font-weight: 700; letter-spacing: -0.02em; color: var(--strong); margin: 0; }
  .section-meta { font-family: "IBM Plex Mono", monospace; font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); }

  /* ---------------- What I do ---------------- */
  .do { display: flex; gap: 16px; margin-bottom: 64px; }
  .do-card {
    flex: 1; padding: 26px 22px; border-radius: 22px; background: var(--surface);
    box-shadow: 7px 7px 16px var(--shd), -7px -7px 16px var(--shl); transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .do-card:hover { transform: translateY(-4px); box-shadow: 11px 13px 26px var(--shd), -11px -11px 26px var(--shl); }
  .do-num { font-family: "Sora", sans-serif; font-size: 14px; font-weight: 700; color: var(--accent); margin-bottom: 14px; }
  .do-title { font-size: 17px; font-weight: 700; color: var(--strong); margin: 0 0 8px; }
  .do-text { font-size: 13.5px; line-height: 1.6; color: var(--dim); margin: 0; }

  /* ---------------- Selected work ---------------- */
  .work-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; scroll-margin-top: 24px; }
  .work { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 64px; }
  .work-card {
    padding: 18px; border-radius: 24px; background: var(--surface);
    box-shadow: 7px 7px 16px var(--shd), -7px -7px 16px var(--shl); transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .work-card:hover { transform: translateY(-4px); box-shadow: 11px 13px 26px var(--shd), -11px -11px 26px var(--shl); }
  .work-thumb {
    border-radius: 16px; background: var(--well); box-shadow: inset 5px 5px 11px var(--shd), inset -5px -5px 11px var(--shl);
    padding: 7px; margin-bottom: 16px;
  }
  .work-thumb img { width: 100%; height: 180px; object-fit: cover; display: block; border-radius: 11px; }
  .thumb-placeholder {
    width: 100%; height: 180px; display: flex; align-items: center; justify-content: center; border-radius: 11px;
    font-family: "IBM Plex Mono", monospace; font-size: 12px; letter-spacing: 0.06em; color: var(--faint);
  }
  .work-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; }
  .work-title { font-size: 17px; font-weight: 700; color: var(--strong); }
  .work-view { text-decoration: none; font-size: 12.5px; font-weight: 700; color: var(--accent); }
  .work-blurb { font-size: 13.5px; line-height: 1.55; color: var(--dim); margin: 0 0 14px; }
  .tags { display: flex; gap: 7px; flex-wrap: wrap; }
  .tag {
    padding: 6px 11px; border-radius: 30px; font-size: 11.5px; font-weight: 600; color: var(--mute);
    background: var(--surface); box-shadow: 3px 3px 6px var(--shd), -3px -3px 6px var(--shl);
  }

  /* ---------------- About ---------------- */
  .about {
    display: flex; gap: 30px; align-items: center; margin-bottom: 64px; scroll-margin-top: 24px;
    padding: 30px; border-radius: 28px; background: var(--surface);
    box-shadow: 7px 7px 16px var(--shd), -7px -7px 16px var(--shl);
  }
  .about-photo {
    flex: none; border-radius: 24px; background: var(--well);
    box-shadow: inset 6px 6px 13px var(--shd), inset -6px -6px 13px var(--shl); padding: 9px;
