const projects = [
  { title: "Coming soon", blurb: "A selected project will live here — what it is, what you shipped, and the outcome.", tags: ["TODO", "TODO"], href: "#", image: null },
  { title: "Coming soon", blurb: "A selected project will live here — what it is, what you shipped, and the outcome.", tags: ["TODO", "TODO"], href: "#", image: null },
